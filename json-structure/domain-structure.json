    },
    "name": {
      "type": "str",
      "description": "name"
    },
    "description": {
      "type": "str",
      "description": "description"
    },
    "status": {
      "type": "str",
      "description": "status"
    },
    "portalUrl": {
      "type": "str",
      "description": "portalUrl"
    },
    "createdAt": {
      "type": "str",
      "description": "createdAt"
    }
  }
}